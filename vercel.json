{
  "version": 2,
  "name": "k8s-three-tier-devsecops",
  "buildCommand": "cd Application-Code/frontend && npm install && npm run build",
  "outputDirectory": "Application-Code/frontend/build",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/health",   "destination": "/api/index.js" },
    { "source": "/(.*)",     "destination": "/Application-Code/frontend/build/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
