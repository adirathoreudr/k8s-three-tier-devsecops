# .env.example
# Copy to .env and fill in real values before running locally.
# NEVER commit .env to git — it is gitignored.

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# ── EKS ───────────────────────────────────────────────────────────────────────
CLUSTER_NAME=aiops-incident-commander
NAMESPACE=aiops

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model config
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Observability stack ───────────────────────────────────────────────────────
LOKI_URL=http://localhost:3100
PROMETHEUS_URL=http://localhost:9090

# ── Service URLs (local dev) ──────────────────────────────────────────────────
COLLECTOR_URL=http://localhost:8000
AGENT_URL=http://localhost:8001
EXECUTOR_URL=http://localhost:8002

# ── ArgoCD ────────────────────────────────────────────────────────────────────
ARGOCD_SERVER=https://argocd.your-domain.com
ARGOCD_TOKEN=

# ── Policy ───────────────────────────────────────────────────────────────────
AUTO_EXECUTE_THRESHOLD=0.75
ESCALATE_THRESHOLD=0.40
BLOCKED_NAMESPACES=kube-system,kube-public,cert-manager
HIGH_RISK_NAMESPACES=production,prod
MIN_CONFIDENCE_AUTO=0.75
MIN_CONFIDENCE_HIGH_RISK=0.90
MAX_SCALE_REPLICAS=20
MIN_SCALE_REPLICAS=1

# ── Collector ─────────────────────────────────────────────────────────────────
DEDUP_WINDOW_SECONDS=120
QUEUE_POLL_INTERVAL=2.0

# ── Executor ─────────────────────────────────────────────────────────────────
RECOVERY_TIMEOUT_SECONDS=120
RECOVERY_POLL_INTERVAL=5.0
IN_CLUSTER=false

# ── Knowledge base ────────────────────────────────────────────────────────────
RUNBOOKS_PATH=./knowledge-base/runbooks
INCIDENTS_PATH=./knowledge-base/incidents
USE_EMBEDDINGS=true
EMBED_MODEL=text-embedding-3-small

# ── UI ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_API_BASE=http://localhost:8000
