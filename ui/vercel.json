{
  "version": 2,
  "name": "aiops-incident-commander",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "env": {
    "NEXT_PUBLIC_DEMO_MODE": "true"
  },
  "framework": "nextjs",
  "outputDirectory": ".next",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install"
}
